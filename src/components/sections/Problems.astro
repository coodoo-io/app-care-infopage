---
const items = [
  // Zeile 1: Differenzierer
  {
    title: 'Vom Report zum Release – alles in einem Tool',
    description: 'Das App-Care Cockpit verbindet KPI-Analyse, Management Summary, Feature-Board und Release Management. Kein Tool-Wechsel, kein Kontext-Verlust – der vollständige Entwicklungskreislauf an einem Ort.',
  },
  {
    title: 'Volle Transparenz per KPI-Report',
    description: 'Installationen, Verweildauer, Abbruchraten — verständlich aufbereitet im monatlichen Management Summary.',
    link: { href: '/management-summary', label: 'Management Summary ansehen' },
  },
  {
    title: 'Feedback in Features verwandeln',
    description: 'Store-Bewertungen, Crashlytics-Daten und KPIs fließen monatlich in den Management Summary. Aus den Handlungsempfehlungen entstehen direkt im Cockpit priorisierte Features – von der Idee bis zum Release.',
  },
  // Zeile 2: Operative Leistungen
  {
    title: 'Sofortreaktion bei Bugs',
    description: 'Kritische Probleme werden behoben, bevor deine Nutzer sie bemerken.',
  },
  {
    title: 'Stabilität durch Monitoring',
    description: 'Probleme werden erkannt und behoben, bevor sie eskalieren.',
  },
  {
    title: 'Kontinuierliche Store-Optimierung',
    description: 'App-Store-Listings werden laufend gepflegt: Texte, Screenshots, Keywords — damit deine App gefunden wird und Nutzer konvertieren.',
  },
  // Zeile 3: Vertrauen
  {
    title: 'Aktuelle Dependencies, immer',
    description: 'Libraries, SDKs und OS-Kompatibilität werden regelmäßig geprüft und aktualisiert — bevor veraltete Abhängigkeiten zum Problem werden.',
  },
  {
    title: 'Kein Recruiting, sofort einsatzbereit',
    description: 'Flexibel skalierbar, monatlich kündbar. Ein eingespieltes Team, das deine App von Anfang an kennt — ohne Onboarding-Aufwand.',
  },
  {
    title: '11 Experten, ein Team',
    description: 'Designer, Entwickler, QA — dauerhaft an deiner Seite. Senior-Level, lokal in Mainz, kein Off- oder Nearshore.',
  },
];
---

<section class="section-padding bg-white">
  <div class="section-container">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="w-8 h-px bg-brand-600"></span>
        <span class="font-display text-xs font-bold tracking-widest uppercase text-brand-600">Leistungen</span>
        <span class="w-8 h-px bg-brand-600"></span>
      </div>
      <h2 class="section-title mb-4">
        Was in deinem Paket steckt
      </h2>
      <p class="section-subtitle">
        Von der KPI-Analyse bis zum Release — alle Leistungen, die monatlich für deine App arbeiten.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="card group">
          <h3 class="font-display font-bold text-base text-slate-900 mb-3">
            {item.title}
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            {item.description}
          </p>
          {item.link && (
            <a
              href={`${import.meta.env.BASE_URL.replace(/\/?$/, '')}${item.link.href}`}
              class="inline-flex items-center gap-1 text-brand-600 text-xs font-semibold mt-4 hover:underline decoration-2 underline-offset-4"
            >
              {item.link.label}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
