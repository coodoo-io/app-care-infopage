---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '');
const logos = [
  { src: `${base}/assets/logos/deutsche-bahn.png`, alt: 'Deutsche Bahn' },
  { src: `${base}/assets/logos/migros.jpg`, alt: 'Migros' },
  { src: `${base}/assets/logos/wuerth.svg`, alt: 'Würth' },
  { src: `${base}/assets/logos/winterhalter.svg`, alt: 'Winterhalter' },
  { src: `${base}/assets/logos/uebe.png`, alt: 'UEBE Medical' },
  { src: `${base}/assets/logos/vereinigte-hagel.svg`, alt: 'Vereinigte Hagel' },
  { src: `${base}/assets/logos/schott.svg`, alt: 'SCHOTT' },
  { src: `${base}/assets/logos/sport1.svg`, alt: 'Sport1' },
  { src: `${base}/assets/logos/immobilien-zeitung.png`, alt: 'Immobilien Zeitung' },
  { src: `${base}/assets/logos/blueplant.png`, alt: 'blueplant' },
  { src: `${base}/assets/logos/gilde-gruppe.png`, alt: 'GILDE Gruppe' },
  { src: `${base}/assets/logos/die-friedliche-geburt.webp`, alt: 'Die Friedliche Geburt' },
];

const metrics = [
  { value: '+51%', label: 'Mehr aktive Nutzer' },
  { value: '+53%', label: 'Mehr Subscriptions' },
  { value: '4,8', label: 'Ø Store-Rating' },
  { value: '99,2%', label: 'Crash-freie Sessions' },
  { value: '< 24h', label: 'Reaktionszeit Store-Reviews' },
  { value: '+28%', label: 'Ø Store-Sichtbarkeit (ASO)' },
];
---

<div class="bg-slate-50 border-y border-slate-100 py-10">

  <p class="text-center font-display text-xs font-bold tracking-widest uppercase text-slate-400 mb-8">
    Vertraut von diesen Unternehmen
  </p>

  <!-- Logos -->
  <div class="section-container mb-10">
    <div id="logo-grid" class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {logos.map((logo) => (
        <div class="h-7 flex items-center justify-center flex-shrink-0">
          <img
            src={logo.src}
            alt={logo.alt}
            class="max-h-7 object-contain opacity-40 grayscale hover:opacity-70 hover:grayscale-0 transition-all duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Metrics -->
  <div class="section-container">
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      {metrics.map((m, i) => (
        <>
          <div class="text-center">
            <div class="font-display font-extrabold text-xl text-slate-900">{m.value}</div>
            <div class="text-xs text-slate-400 mt-0.5">{m.label}</div>
          </div>
          {i < metrics.length - 1 && (
            <div class="hidden sm:block w-px h-6 bg-slate-200" />
          )}
        </>
      ))}
    </div>
  </div>

</div>

<script>
  const grid = document.getElementById('logo-grid');
  if (grid) {
    const items = Array.from(grid.children);
    items.sort(() => Math.random() - 0.5).forEach(el => grid.appendChild(el));
  }
</script>
