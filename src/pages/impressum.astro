---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impressum | App-Care"
  description="Impressum der App-Care Website — ein Service der coodoo GmbH."
  noindex={true}
>
  <section class="section-padding bg-white">
    <div class="section-container max-w-2xl mx-auto">

      <div class="mb-12">
        <span class="font-display text-xs font-bold tracking-widest uppercase text-brand-600">Rechtliches</span>
        <h1 class="font-display font-bold text-3xl text-slate-900 mt-3">Impressum</h1>
      </div>

      <div class="divide-y divide-slate-100">

        <div class="py-8 grid grid-cols-1 sm:grid-cols-3 gap-2">
          <p class="font-display font-bold text-xs tracking-widest uppercase text-slate-400">Angaben gemäß § 5 TMG</p>
          <div class="sm:col-span-2 text-slate-700 text-sm leading-relaxed">
            coodoo GmbH<br />
            Jakob-Anstatt-Str. 2<br />
            55130 Mainz
          </div>
        </div>

        <div class="py-8 grid grid-cols-1 sm:grid-cols-3 gap-2">
          <p class="font-display font-bold text-xs tracking-widest uppercase text-slate-400">Kontakt</p>
          <div class="sm:col-span-2 text-slate-700 text-sm leading-relaxed">
            Telefon: 06131 / 4640270<br />
            E-Mail: <a href="mailto:mail@coodoo.de" class="text-brand-600 hover:underline">mail@coodoo.de</a>
          </div>
        </div>

        <div class="py-8 grid grid-cols-1 sm:grid-cols-3 gap-2">
          <p class="font-display font-bold text-xs tracking-widest uppercase text-slate-400">Geschäftsführung</p>
          <div class="sm:col-span-2 text-slate-700 text-sm">
            Markus Kühle, Jan Marsh
          </div>
        </div>

        <div class="py-8 grid grid-cols-1 sm:grid-cols-3 gap-2">
          <p class="font-display font-bold text-xs tracking-widest uppercase text-slate-400">Handelsregister</p>
          <div class="sm:col-span-2 text-slate-700 text-sm leading-relaxed">
            Registergericht: Amtsgericht Mainz<br />
            Registernummer: HRB 44076
          </div>
        </div>

        <div class="py-8 grid grid-cols-1 sm:grid-cols-3 gap-2">
          <p class="font-display font-bold text-xs tracking-widest uppercase text-slate-400">Umsatzsteuer-ID</p>
          <div class="sm:col-span-2 text-slate-700 text-sm">
            DE283497556
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
