---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt & Gespräch buchen | App-Care"
  description="Kontaktiere App-Care für ein kostenloses Beratungsgespräch. Buche direkt einen Termin oder schreib uns."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-20">
    <div class="section-container text-center">
      <span class="badge bg-white/5 text-slate-300 mb-4 inline-block">Kostenloses Erstgespräch</span>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-6">
        Lass uns reden
      </h1>
      <p class="text-slate-300 text-xl max-w-2xl mx-auto">
        30 Minuten. Kein Pitch. Kein Druck. Wir schauen gemeinsam, ob und wie App-Care deiner App helfen kann.
      </p>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="section-padding bg-white">
    <div class="section-container max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: Form -->
        <div>
          <h2 class="font-display font-bold text-2xl text-slate-900 mb-2">Schreib uns</h2>
          <p class="text-slate-600 mb-6">Wir antworten innerhalb von wenigen Stunden.</p>

          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Max Mustermann"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1">E-Mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="max@meinapp.de"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
                />
              </div>
            </div>

            <div>
              <label for="app" class="block text-sm font-medium text-slate-700 mb-1">Deine App</label>
              <input
                type="text"
                id="app"
                name="app"
                placeholder="Name deiner App (optional)"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
              />
            </div>

            <div>
              <p class="block text-sm font-medium text-slate-700 mb-2">Worum geht es? <span class="text-slate-400 font-normal">(optional)</span></p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="interesse-options">
                {[
                  { value: 'erstgespraech', label: 'Erstgespräch buchen', sub: '30 Min., kostenlos & unverbindlich' },
                  { value: 'cockpit', label: 'App-Cockpit testen', sub: 'Solo-Zugang, keine Teambetreuung' },
                  { value: 'teambetreuung', label: 'Teambetreuung anfragen', sub: 'Monatliche Betreuung mit festem Team' },
                  { value: 'unsicher', label: 'Noch unsicher', sub: 'Einfach mal schauen, was möglich ist' },
                ].map(({ value, label, sub }) => (
                  <label class="interesse-card flex flex-col gap-0.5 px-4 py-3 rounded-xl border border-slate-200 cursor-pointer hover:border-brand-400 transition-colors has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50">
                    <input type="radio" name="paket" value={value} class="sr-only" />
                    <span class="text-sm font-medium text-slate-900">{label}</span>
                    <span class="text-xs text-slate-500">{sub}</span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Nachricht *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                placeholder="Erzähl uns kurz von deiner App und was du dir von App-Care erhoffst..."
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow resize-none"
              ></textarea>
            </div>

            <!-- Honeypot: für echte Nutzer unsichtbar, Bots füllen es aus -->
            <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;">
              <label for="website">Website leer lassen</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div id="form-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
              Etwas ist schiefgelaufen. Bitte versuche es erneut oder schreib uns direkt an info@app-care.de.
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="btn-primary w-full text-base"
            >
              Anfrage senden →
            </button>

            <p class="text-xs text-slate-400 text-center">
              Deine Daten werden nur zur Bearbeitung deiner Anfrage genutzt.
            </p>
          </form>

          <div id="form-success" class="hidden rounded-xl bg-brand-50 border border-brand-200 px-6 py-8 text-center">
            <svg class="w-10 h-10 text-brand-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <p class="font-display font-bold text-slate-900 text-lg mb-1">Nachricht erhalten.</p>
            <p class="text-slate-600 text-sm">Wir melden uns innerhalb von wenigen Stunden bei dir.</p>
          </div>

          <script define:vars={{ apiUrl: import.meta.env.PUBLIC_CONTACT_API_URL }}>
            const form = document.getElementById('contact-form');
            const successEl = document.getElementById('form-success');
            const errorEl = document.getElementById('form-error');
            const submitBtn = document.getElementById('submit-btn');

            form?.addEventListener('submit', async (e) => {
              e.preventDefault();
              errorEl.classList.add('hidden');
              submitBtn.disabled = true;
              submitBtn.textContent = 'Wird gesendet…';

              if (form.website.value) return; // Honeypot ausgelöst → still ignorieren

              const data = {
                name: form.name.value,
                email: form.email.value,
                app: form.app.value,
                message: `Paket: ${form.paket.value || '–'}\n\n${form.message.value}`,
                website: form.website.value, // Honeypot — Edge Function prüft ob leer
              };

              try {
                const res = await fetch(apiUrl, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data),
                });
                if (!res.ok) throw new Error();
                form.classList.add('hidden');
                successEl.classList.remove('hidden');
              } catch {
                errorEl.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Anfrage senden →';
              }
            });
          </script>
        </div>

        <!-- Right: Ansprechpartner + Calendly + Info -->
        <div class="space-y-8">

          <!-- Markus Kühle — Ansprechpartner -->
          <div class="card border border-slate-100 flex gap-5 items-start">
            <img
              src={`${import.meta.env.BASE_URL.replace(/\/?$/, '')}/assets/Markus.jpg`}
              alt="Markus Kühle, Geschäftsführer coodoo GmbH"
              class="w-20 h-20 rounded-full object-cover flex-shrink-0 shadow-sm"
            />
            <div>
              <p class="font-display font-bold text-slate-900 text-lg leading-tight">Markus Kühle</p>
              <p class="text-brand-600 text-sm font-medium mb-2">Direkt. Persönlich. Ohne Umweg.</p>
              <p class="text-slate-500 text-sm leading-relaxed mb-3">
                Du sprichst direkt mit mir — kein Vertrieb, kein Umweg.
              </p>
              <a
                href="https://www.linkedin.com/in/markus-kuehle/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs text-brand-600 hover:text-brand-700 font-medium transition-colors"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn-Profil
              </a>
            </div>
          </div>

          <!-- Google Calendar Appointment -->
          <div class="card border-2 border-brand-100 bg-brand-50">
            <h2 class="font-display font-bold text-xl text-slate-900 mb-2">Direkt Termin buchen</h2>
            <p class="text-slate-600 text-sm mb-6">
              Lieber gleich einen Gesprächstermin auswählen? Buche direkt einen freien Slot in unserem Kalender.
            </p>
            <div class="flex flex-col gap-3 text-sm text-slate-500 mb-6">
              {[
                '30 Minuten · kostenlos · unverbindlich',
                'Kein Pitch, nur ehrliche Beratung',
                'Du sprichst direkt mit Markus',
              ].map(item => (
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-brand-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </div>
              ))}
            </div>
            <a
              href="https://calendar.app.google/NezvtYoUMT2Bea6z6"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-full text-center"
            >
              Termin buchen →
            </a>
          </div>

          <!-- Contact Info -->
          <div class="card border border-slate-100">
            <h3 class="font-display font-semibold text-slate-900 mb-4">Kontaktdaten</h3>
            <address class="not-italic space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <span class="text-lg">🏢</span>
                <div>
                  <p class="font-medium text-slate-900">coodoo GmbH</p>
                  <p class="text-slate-600">Mainz, Deutschland</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg">✉️</span>
                <a href="mailto:info@app-care.de" class="text-brand-600 hover:underline">
                  info@app-care.de
                </a>
              </div>
            </address>
          </div>

          <!-- Trust signals -->
          <div class="space-y-3">
            {[
              'Antwort innerhalb von wenigen Stunden',
              'Kostenlos & unverbindlich',
              'Kein Pitch, nur ehrliche Beratung',
              '20+ Jahre Berufserfahrung im Team',
            ].map((item) => (
              <div class="flex items-center gap-2 text-sm text-slate-600">
                <svg class="w-4 h-4 text-brand-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
