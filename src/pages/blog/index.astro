---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const formatDate = (date: Date) =>
  date.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog | App-Care"
  description="App-Care Blog: KPI-Guides, App-Wachstumsstrategien und Insights für Mobile App Betreiber."
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-20">
    <div class="section-container">
      <div class="max-w-3xl">
        <span class="badge bg-white/5 text-slate-300 mb-4 inline-block">App-Care Blog</span>
        <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-6">
          Wissen für App-Betreiber
        </h1>
        <p class="text-slate-300 text-xl leading-relaxed">
          KPI-Guides, App-Wachstumsstrategien und praxisnahe Insights — von App-Experten für App-Betreiber.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="section-padding bg-white">
    <div class="section-container max-w-6xl mx-auto">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-slate-500 text-lg">Erste Artikel erscheinen bald.</p>
          <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '')}/kpis`} class="btn-primary mt-6">KPI Ratgeber lesen</a>
        </div>
      ) : (
        <div>
          {/* Featured article */}
          {featured && (
            <article class="group mb-12 rounded-2xl border border-slate-100 hover:border-brand-200 transition-colors bg-white overflow-hidden md:flex md:gap-0">
              <div class="md:w-2/3 p-8 md:p-10 flex flex-col justify-between">
                <div>
                  <div class="flex items-center gap-2 mb-4">
                    <span class="badge-brand text-xs">{featured.data.category}</span>
                    <span class="badge bg-brand-50 text-brand-700 text-xs">Neuester Artikel</span>
                    <time class="text-xs text-slate-400">{formatDate(featured.data.pubDate)}</time>
                  </div>
                  <h2 class="font-display font-bold text-2xl md:text-3xl text-slate-900 mb-4 group-hover:text-brand-600 transition-colors">
                    <a href={`/blog/${featured.id}`}>{featured.data.title}</a>
                  </h2>
                  <p class="text-slate-600 leading-relaxed mb-6">{featured.data.description}</p>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-slate-400">von {featured.data.author}</span>
                  <a href={`/blog/${featured.id}`} class="btn-primary text-sm">Artikel lesen →</a>
                </div>
              </div>
              <div class="md:w-1/3 bg-brand-950 flex items-center justify-center p-10 min-h-[200px]">
                <div class="text-center">
                  <p class="font-display font-bold text-5xl text-white/10 leading-none mb-2">01</p>
                  <p class="font-display font-bold text-white text-lg leading-tight">{featured.data.category}</p>
                </div>
              </div>
            </article>
          )}

          {/* Rest: 3 per row */}
          {rest.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {rest.map((post) => (
                <article class="card border border-slate-100 hover:border-brand-200 transition-colors group flex flex-col">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="badge-brand text-xs">{post.data.category}</span>
                    <time class="text-xs text-slate-400">{formatDate(post.data.pubDate)}</time>
                  </div>
                  <h2 class="font-display font-bold text-lg text-slate-900 mb-2 group-hover:text-brand-600 transition-colors flex-1">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <p class="text-slate-600 text-sm leading-relaxed mb-4 line-clamp-3">{post.data.description}</p>
                  <div class="flex items-center justify-between mt-auto">
                    <span class="text-xs text-slate-400">von {post.data.author}</span>
                    <a href={`/blog/${post.id}`} class="text-brand-600 text-sm font-medium hover:underline">
                      Weiterlesen →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding gradient-section">
    <div class="section-container text-center max-w-2xl mx-auto">
      <h2 class="section-title mb-4">Deine App professionell betreuen lassen</h2>
      <p class="section-subtitle mb-8">App-Care überwacht, analysiert und entwickelt deine App kontinuierlich weiter — KPI-getrieben und messbar.</p>
      <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '')}/kontakt`} class="btn-primary">Kostenloses Erstgespräch buchen</a>
    </div>
  </section>
</BaseLayout>
